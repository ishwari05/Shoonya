{
	"name": "shoonya-security",
	"displayName": "Shoonya Security",
	"description": "Protect developers from accidentally exposing secrets while coding, copying, pasting into AI tools, and committing to Git",
	"version": "1.0.0",
	"publisher": "shoonya",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"security",
		"secrets",
		"api keys",
		"tokens",
		"passwords",
		"ai safety",
		"git protection"
	],
	"activationEvents": [
		"onStartupFinished",
		"onLanguage:javascript",
		"onLanguage:typescript",
		"onLanguage:json",
		"onLanguage:python",
		"onLanguage:java",
		"onLanguage:go",
		"onLanguage:rust",
		"onLanguage:cpp",
		"onLanguage:c"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "shoonya.redactSecrets",
				"title": "Shoonya: Redact Secrets",
				"icon": "$(shield)"
			},
			{
				"command": "shoonya.scanDocument",
				"title": "Shoonya: Scan Document for Secrets",
				"icon": "$(search)"
			},
			{
				"command": "shoonya.quickRedact",
				"title": "Shoonya: Quick Redact (No Confirmation)",
				"icon": "$(zap)"
			},
			{
				"command": "shoonya.ignoreSecret",
				"title": "Shoonya: Ignore This Secret",
				"icon": "$(eye-off)"
			},
			{
				"command": "shoonya.addToSafeList",
				"title": "Shoonya: Add to Safe List",
				"icon": "$(check)"
			}
		],
		"configuration": {
			"title": "Shoonya Security",
			"properties": {
				"shoonya.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable Shoonya secret detection"
				},
				"shoonya.autoRedact": {
					"type": "boolean",
					"default": false,
					"description": "Automatically redact secrets before saving"
				},
				"shoonya.entropyThreshold": {
					"type": "number",
					"default": 4.2,
					"description": "Entropy threshold for detecting high-entropy strings"
				},
				"shoonya.excludedFiles": {
					"type": "array",
					"default": [],
					"description": "File patterns to exclude from scanning"
				},
				"shoonya.showNotifications": {
					"type": "boolean",
					"default": true,
					"description": "Show notifications when secrets are detected"
				},
				"shoonya.clipboardProtection": {
					"type": "boolean",
					"default": true,
					"description": "Enable clipboard protection"
				},
				"shoonya.gitProtection": {
					"type": "boolean",
					"default": true,
					"description": "Enable Git commit protection"
				},
				"shoonya.maxSecretsPerFile": {
					"type": "number",
					"default": 50,
					"description": "Maximum number of secrets to detect per file"
				}
			}
		},
		"menus": {
			"editor/context": [
				{
					"command": "shoonya.redactSecrets",
					"group": "shoonya",
					"when": "editorHasSelection"
				},
				{
					"command": "shoonya.scanDocument",
					"group": "shoonya"
				}
			],
			"editor/title": [
				{
					"command": "shoonya.scanDocument",
					"when": "editorTextFocus",
					"group": "navigation"
				}
			],
			"commandPalette": [
				{
					"command": "shoonya.redactSecrets",
					"when": "editorHasSelection"
				}
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -w -p ./",
		"clean": "rimraf dist",
		"build": "npm run clean && npm run compile",
		"test": "node simple_test.js",
		"test:engine": "node -e \"const engine = require('./dist/engine/index.js'); console.log('Engine test:', engine.quickScan('sk-1234567890abcdef'));\"",
		"copy-engine": "node -e \"require('fs').cpSync('engine','dist/engine',{recursive:true})\"",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts"
	},
	"devDependencies": {
		"@types/vscode": "^1.85.0",
		"@types/node": "18.x",
		"@typescript-eslint/eslint-plugin": "^6.13.0",
		"@typescript-eslint/parser": "^6.13.0",
		"eslint": "^8.54.0",
		"typescript": "^5.3.0"
	},
	"dependencies": {
		"vscode-languageclient": "^9.0.1"
	}
}
